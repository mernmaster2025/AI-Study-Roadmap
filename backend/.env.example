# Copy to backend/.env and adjust.

# ---- Database ----
# Postgres (primary). Uses the psycopg 3 driver; install it with:
#   pip install -r requirements-postgres.txt
# Create the role + database first with:  python setup_db.py   (see README)
DATABASE_URL=postgresql+psycopg://study:study@localhost:5432/study_platform

# SQLite fallback (zero setup, no server) — uncomment to use instead:
# DATABASE_URL=sqlite:///./study_platform.db

# ---- Auth (CHANGE in any shared/production environment) ----
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ---- Code execution sandbox ----
CODE_TIMEOUT_SECONDS=5
MAX_CODE_LENGTH=20000

# ---- Frontend / CORS ----
# FRONTEND_ORIGIN: single base URL used to build OAuth redirect targets.
FRONTEND_ORIGIN=http://localhost:3000
# CORS_ORIGINS: comma-separated list of allowed browser origins (use for
# explicit production origins). localhost and 127.0.0.1 are DISTINCT origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ORIGIN_REGEX: fallback so ANY local dev port is allowed (Next.js hops to
# 3001/3002 when a port is taken). Set to empty in production to lock this down.
CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1)(:\d+)?$

# ---- OAuth (optional) ----
# Leave blank to disable a provider; dev-login still works and the sign-in page
# only shows the providers you configure here.
# GitHub:  https://github.com/settings/developers  (callback:
#   http://localhost:8000/api/auth/callback/github)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google:  https://console.cloud.google.com/apis/credentials  (redirect URI:
#   http://localhost:8000/api/auth/callback/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
