# Copy to backend/.env and adjust as needed. All values have sane defaults.

# SQLite (default, zero setup). For Supabase/Postgres use e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./study_platform.db

# Auth — CHANGE THIS in any shared/production environment.
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Code execution sandbox
CODE_TIMEOUT_SECONDS=5
MAX_CODE_LENGTH=20000

# CORS: the Next.js dev server origin
FRONTEND_ORIGIN=http://localhost:3000
